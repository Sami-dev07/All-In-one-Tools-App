<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="5">

        <TextView
            android:id="@+id/tv_content_1"
            style="@style/textStyleSubtitle1Regular"
            android:layout_width="150dp"
            android:layout_height="match_parent"
            android:layout_gravity="top"
            android:layout_weight="1"
            android:background="@drawable/table_content_cell_bg"
            android:gravity="center"
            android:text="" />

        <TextView
            android:id="@+id/tv_content_2"
            style="@style/textStyleSubtitle1Regular"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_weight="1"
            android:background="@drawable/table_content_cell_bg"
            android:gravity="center"
            android:text="" />

        <TextView
            android:id="@+id/tv_content_3"
            style="@style/textStyleSubtitle1Regular"
            android:layout_width="150dp"
            android:layout_height="match_parent"
            android:layout_gravity="top"
            android:layout_weight="1"
            android:background="@drawable/table_content_cell_bg"
            android:gravity="center"
            android:text="" />

        <TextView
            android:id="@+id/tv_content_4"
            style="@style/textStyleSubtitle1Regular"
            android:layout_width="150dp"
            android:layout_height="match_parent"
            android:layout_gravity="top"
            android:layout_weight="1"
            android:background="@drawable/table_content_cell_bg"
            android:gravity="center"
            android:text="" />

        <TextView
            android:id="@+id/tv_content_5"
            style="@style/textStyleSubtitle1Regular"
            android:layout_width="150dp"
            android:layout_height="match_parent"
            android:layout_gravity="top"
            android:layout_weight="1"
            android:background="@drawable/table_content_cell_bg"
            android:gravity="center"
            android:text="" />
    </LinearLayout>
</LinearLayout>
